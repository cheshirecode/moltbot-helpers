{
  "paths": [
    {"glob": "~/documents/**/*.md", "label": "documents"},
    {"glob": "~/notes/**/*.txt", "label": "notes"}
  ],
  "sqliteSources": [
    {"path": "~/data/mydb.db", "tables": ["notes", "tasks"], "label": "my-database"}
  ],
  "model": "all-MiniLM-L6-v2",
  "dbPath": "~/.local/share/seek/seek.db",
  "chunkSize": 256,
  "chunkOverlap": 32
}
